{
    "comoFuncionaCalculoHoras": {
        "titulo": "Kaip veikia valandų skaičiavimas My Clock programoje",
        "introducao": {
            "paragrafo1": "My Clock buvo sukurtas taip, kad kuo tiksliau atkartotų įmonėje taikomas darbo valandų skaičiavimo taisykles, leidžiant kiekvienam darbuotojui sekti savo dirbtas valandas, viršvalandžius ir apskaičiuotą bruto atlyginimą.",
            "paragrafo2": "Žemiau pateikiamas paaiškinimas, kaip atliekami skaičiavimai programoje."
